{
  "name": "DAP Development",
  "image": "ghcr.io/eth-library/nix-aerie-python:latest",
  "remoteUser": "dev",
  "onCreateCommand": "direnv allow . && direnv exec . true",
  "customizations": {
    "vscode": {
      "extensions": [
        "jnoortheen.nix-ide",
        /*
         * direnv extension (mkhl.direnv) not needed:
         * - bash hook handles terminal environment
         * - python extension auto-discovers .venv
         * - avoids reload prompt on codespace startup
         */
        "ms-python.python",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.terminal.activateEnvironment": false,
        "terminal.integrated.shellIntegration.enabled": true
      }
    }
  }
}
